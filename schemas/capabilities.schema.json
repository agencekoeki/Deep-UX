{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capabilities",
  "description": "Cartographie des capacités fonctionnelles réelles trouvées dans le code",
  "type": "object",
  "required": ["generated_at", "capabilities", "total_capabilities", "implemented_count", "partial_count"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "description", "evidence", "status", "exposed_in_ui", "screens_where_used"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^cap-[0-9]+$"
          },
          "name": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["auth", "data", "navigation", "action", "integration", "notification", "export", "search", "filter", "other"]
          },
          "description": { "type": "string" },
          "evidence": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["implemented", "partial", "commented_only"]
          },
          "exposed_in_ui": { "type": "boolean" },
          "screens_where_used": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "total_capabilities": { "type": "integer", "minimum": 0 },
    "implemented_count": { "type": "integer", "minimum": 0 },
    "partial_count": { "type": "integer", "minimum": 0 }
  }
}
