{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Report CC Tasks",
  "description": "Liste de tickets actionnables pour une session Claude Code d'implémentation",
  "type": "object",
  "required": ["generated_at", "project_name", "tasks"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "project_name": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "priority", "effort", "category", "source_recommendations", "files_to_modify"],
        "properties": {
          "id": { "type": "string", "pattern": "^task-[0-9]+$" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "priority": { "type": "string", "enum": ["must", "should", "could", "wont"] },
          "effort": { "type": "string", "enum": ["xs", "s", "m", "l", "xl"] },
          "category": { "type": "string", "enum": ["visual", "functional", "content", "structural", "accessibility", "performance"] },
          "source_recommendations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "files_to_modify": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_tasks": { "type": "integer" },
        "must_count": { "type": "integer" },
        "should_count": { "type": "integer" },
        "could_count": { "type": "integer" },
        "estimated_total_effort": { "type": "string" }
      }
    }
  }
}
